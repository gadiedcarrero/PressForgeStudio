# ─── PressForge Studio · configuración ───────────────────────────────
# Copia este archivo a `.env` y rellena tu API key.

# REQUERIDO: tu clave de OpenAI (cubre guion, imágenes y voz en V1)
OPENAI_API_KEY=sk-...

# ─── Selección de providers ──────────────────────────────────────────
# SCRIPT_PROVIDER: 'openai' (pago, máxima calidad) o 'ollama' (local gratis)
SCRIPT_PROVIDER=openai
# IMAGE_PROVIDER: 'openai' (pago, gpt-image-1) o 'local' (GRATIS, ComfyUI en tu Mac
# con SDXL + InstantID para misma cara entre escenas). Para 'local' arranca antes
# ComfyUI con tools/run_comfyui.command.
#   Velocidad/encuadre (solo 'local'): COMFYUI_LIGHTNING_LORA acelera ~4× (8 pasos);
#   déjalo vacío para 30 pasos (más calidad, más lento). INSTANTID_WEIGHT (0-1):
#   ↑ fija más la cara (primer plano), ↓ abre el encuadre (pero puede dar artefactos).
#   El estilo "anime" usa un modelo SDXL anime aparte (COMFYUI_ANIME_CHECKPOINT).
#   VIDEO LOCAL (animación gratis con LTX en ComfyUI): se elige en la UI (Formato →
#   "Video animado · TODO Local"). Ajustes: COMFYUI_VIDEO_MODEL / _STEPS / _CFG.
IMAGE_PROVIDER=openai
# VOICE_PROVIDER: 'kokoro' (LOCAL gratis) · 'openai' (barato) · 'elevenlabs' (premium, muy natural)
VOICE_PROVIDER=openai
# SUBTITLE_PROVIDER: 'whisper-local' (GRATIS, faster-whisper en tu Mac) o 'whisper' (OpenAI, pago)
SUBTITLE_PROVIDER=whisper-local
RENDER_PROVIDER=ffmpeg
MUSIC_PROVIDER=local
RESEARCH_PROVIDER=wikipedia

# ─── Modelos ──────────────────────────────────────────────────────────
SCRIPT_MODEL=gpt-4o
IMAGE_MODEL=gpt-image-1
VOICE_MODEL=gpt-4o-mini-tts
SUBTITLE_MODEL=whisper-1

# ─── Ollama (guion local GRATIS) — pon SCRIPT_PROVIDER=ollama para usarlo ──
# Requiere Ollama + modelo: rápido "qwen2.5:7b-instruct" (~1.5 min) o mejor calidad "qwen3:30b" (~3 min)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5:7b-instruct

# ─── ElevenLabs (voz premium) — pon VOICE_PROVIDER=elevenlabs para usarlo ──
# La API key va en Ajustes → API Keys (o aquí). El voice_id lo sacas de tu panel → Voces.
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb
ELEVENLABS_MODEL=eleven_multilingual_v2

# ─── Voz ──────────────────────────────────────────────────────────────
# Voces OpenAI: alloy, ash, ballad, coral, echo, fable, onyx, nova, sage, shimmer
VOICE_NAME=onyx
# Instrucción de tono para gpt-4o-mini-tts (ignorada por tts-1)
VOICE_INSTRUCTIONS=Narrador de documental histórico. Tono dramático, intrigante y cinematográfico. Ritmo ágil. Español neutro.

# ─── Idioma del contenido ─────────────────────────────────────────────
LANGUAGE=es

# ─── Almacenamiento compartido entre PCs (Google Drive / Dropbox) ─────
# Carpeta base donde se guardan TUS marcas y TUS reels. Apúntala a la MISMA
# carpeta sincronizada en cada PC y tendrás todo el contenido en cualquier
# equipo (Mac o Windows). Déjala vacía para usar la carpeta del proyecto.
#
#   Mac:     STORAGE_DIR=/Users/TU_USUARIO/Library/CloudStorage/GoogleDrive-tucorreo@gmail.com/My Drive/PressForge
#   Mac (Dropbox):  STORAGE_DIR=/Users/TU_USUARIO/Dropbox/PressForge
#   Windows: STORAGE_DIR=G:\My Drive\PressForge     (o)  C:\Users\TU_USUARIO\Dropbox\PressForge
#
# Crea las subcarpetas `data/` y `output/` solo; la app las genera al usarlas.
STORAGE_DIR=
# (Opcional) afinar cada carpeta por separado; tienen prioridad sobre STORAGE_DIR.
# DATA_DIR=
# OUTPUT_DIR=
# MUSIC_DIR=     (biblioteca de música; por defecto assets/music o STORAGE_DIR/music)

# ─── Render ───────────────────────────────────────────────────────────
FPS=30
VIDEO_WIDTH=1080
VIDEO_HEIGHT=1920
IMAGE_QUALITY=medium
# Volumen de la música de fondo respecto a la narración (0.0 - 1.0)
MUSIC_VOLUME=0.12
