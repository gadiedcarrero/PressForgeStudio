# ─── PressForge Studio · configuración ───────────────────────────────
# Copia este archivo a `.env` y rellena tu API key.

# REQUERIDO: tu clave de OpenAI (cubre guion, imágenes y voz en V1)
OPENAI_API_KEY=sk-...

# ─── Selección de providers (V1 solo trae 'openai' / 'whisper' / 'ffmpeg') ──
SCRIPT_PROVIDER=openai
IMAGE_PROVIDER=openai
VOICE_PROVIDER=openai
SUBTITLE_PROVIDER=whisper
RENDER_PROVIDER=ffmpeg
MUSIC_PROVIDER=local

# ─── Modelos ──────────────────────────────────────────────────────────
SCRIPT_MODEL=gpt-4o
IMAGE_MODEL=gpt-image-1
VOICE_MODEL=gpt-4o-mini-tts
SUBTITLE_MODEL=whisper-1

# ─── Voz ──────────────────────────────────────────────────────────────
# Voces OpenAI: alloy, ash, ballad, coral, echo, fable, onyx, nova, sage, shimmer
VOICE_NAME=onyx
# Instrucción de tono para gpt-4o-mini-tts (ignorada por tts-1)
VOICE_INSTRUCTIONS=Narrador de documental histórico. Tono dramático, intrigante y cinematográfico. Ritmo ágil. Español neutro.

# ─── Idioma del contenido ─────────────────────────────────────────────
LANGUAGE=es

# ─── Render ───────────────────────────────────────────────────────────
FPS=30
VIDEO_WIDTH=1080
VIDEO_HEIGHT=1920
IMAGE_QUALITY=medium
# Volumen de la música de fondo respecto a la narración (0.0 - 1.0)
MUSIC_VOLUME=0.12
